{
  "providers": ["node"],
  "apt": {
    "packages": [
      "ffmpeg",
      "chromium",
      "libnss3",
      "libatk1.0-0",
      "libatk-bridge2.0-0",
      "libcups2",
      "libdrm2",
      "libxkbcommon0",
      "libxcomposite1",
      "libxdamage1",
      "libxrandr2",
      "libgbm1",
      "libpango-1.0-0",
      "libasound2",
      "libxshmfence1",
      "fonts-noto-color-emoji"
    ]
  },
  "variables": {
    "NIXPACKS_NODE_VERSION": "20",
    "PUPPETEER_SKIP_CHROMIUM_DOWNLOAD": "true",
    "PUPPETEER_EXECUTABLE_PATH": "/usr/bin/chromium"
  }
}
